{% comment %} Product detail page — image gallery + add to cart. {% endcomment %}

<section>
  <div class="cb-container">
    {% if product %}
      <div class="cb-product">
        <div class="cb-product-gallery cb-anim-up">
          {% if product.imageUrl != blank %}
            <img src="{{ product.imageUrl }}" alt="{{ product.name }}">
          {% else %}
            <div class="cb-skeleton" style="width:100%;height:100%;"></div>
          {% endif %}
        </div>

        <div class="cb-product-info cb-anim-up delay-1">
          {% if product.collectionTitle %}
            <a href="/category/{{ product.collectionHandle }}" style="display: inline-block; color: var(--color-primary); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px;">← {{ product.collectionTitle }}</a>
          {% endif %}
          <h1>{{ product.name }}</h1>
          {% if product.tagline %}<p class="cb-product-tagline">{{ product.tagline }}</p>{% endif %}

          <div class="cb-product-price">{{ product.price | money }}</div>

          {% if product.description %}
            <p class="cb-product-desc">{{ product.description }}</p>
          {% endif %}

          {% if product.calories %}
            <div style="display: inline-flex; align-items: center; gap: 16px; padding: 12px 18px; background: var(--color-bg); border-radius: var(--radius-md); margin-bottom: 22px; font-size: 0.85rem; color: var(--color-muted);">
              <span>🔥 {{ product.calories }} cal</span>
              {% if product.tags contains 'veg' %}<span>🌱 Vegetarian</span>{% endif %}
              {% if product.tags contains 'spicy' %}<span>🌶️ Spicy</span>{% endif %}
            </div>
          {% endif %}

          {% if product.modifier_groups and product.modifier_groups.size > 0 %}
            <div class="cb-modifier-groups">
              {% for group in product.modifier_groups %}
                <div class="cb-modifier-group" data-group-id="{{ group.id }}" data-group-required="{{ group.required }}" data-group-min="{{ group.min }}" data-group-max="{{ group.max }}">
                  <div class="cb-modifier-group-title">
                    {{ group.title }}
                    {% if group.required %}<span class="cb-modifier-required">Required</span>{% endif %}
                  </div>
                  <div class="cb-modifier-options">
                    {% for option in group.options %}
                      <label class="cb-modifier-option">
                        {% if group.max == 1 %}
                          <input type="radio" name="modifier_group_{{ group.id }}" value="{{ option.id }}" data-price-delta="{{ option.price_delta }}" data-option-name="{{ option.label }}" data-group-name="{{ group.title }}"{% if option.is_default %} checked{% endif %}>
                        {% else %}
                          <input type="checkbox" name="modifier_group_{{ group.id }}" value="{{ option.id }}" data-price-delta="{{ option.price_delta }}" data-option-name="{{ option.label }}" data-group-name="{{ group.title }}"{% if option.is_default %} checked{% endif %}>
                        {% endif %}
                        <span class="cb-modifier-option-label">
                          <span class="cb-modifier-option-name">{{ option.label }}</span>
                          {% if option.price_delta and option.price_delta > 0 %}
                            <span class="cb-modifier-option-price">+{{ option.price_delta_money }}</span>
                          {% endif %}
                        </span>
                      </label>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          <div class="cb-product-actions">
            <div class="cb-qty" data-cb-qty>
              <button type="button" data-cb-qty-step="-1" aria-label="Decrease">−</button>
              <input type="text" value="1" readonly>
              <button type="button" data-cb-qty-step="1" aria-label="Increase">+</button>
            </div>
            <button type="button" class="cb-btn cb-btn-primary cb-btn-lg" id="cb-add-to-cart-btn">
              Add to cart · {{ product.price | money }}
            </button>
          </div>

          <script type="application/json" id="product-data">
          {
            "id": "{{ product.id }}",
            "name": {{ product.name | json }},
            "price": {{ product.price }},
            "image_url": {{ product.imageUrl | default: "" | json }},
            "modifier_groups": {{ product.modifier_groups | json }}
          }
          </script>

          {% if ordering.whatsapp_order_enabled %}
            <a href="{{ ordering.whatsapp_order_href }}" target="_blank" rel="noopener" class="cb-btn cb-btn-outline cb-btn-block">
              💬 Order on WhatsApp
            </a>
          {% endif %}
        </div>
      </div>

      {% if product.relatedItems and product.relatedItems.size > 0 %}
        <div style="margin-top: 64px;">
          <h2 style="margin-bottom: 24px;">You might also like</h2>
          <div class="cb-grid" style="--cb-cols: 4;">
            {% for rel in product.relatedItems %}
              <a href="{{ rel.url }}" class="cb-card--minimal">
                <div class="cb-card-img">
                  {% if rel.imageUrl %}<img src="{{ rel.imageUrl }}" alt="{{ rel.name }}" loading="lazy">{% else %}<div class="cb-skeleton" style="width:100%;height:100%;"></div>{% endif %}
                </div>
                <div class="cb-card-title">{{ rel.name }}</div>
                <div class="cb-card-price">{{ rel.price | money }}</div>
              </a>
            {% endfor %}
          </div>
        </div>
      {% endif %}

    {% else %}
      <div style="padding: 80px 0; text-align: center;">
        <h2>Product not found</h2>
        <p>Try browsing our <a href="/menu" style="color: var(--color-primary); font-weight: 600;">full menu</a>.</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product Detail",
  "settings": [],
  "presets": [{ "name": "Product Detail", "settings": {} }]
}
{% endschema %}
