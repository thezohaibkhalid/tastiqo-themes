{% comment %} Cart page — JS-rendered from localStorage. {% endcomment %}

<section data-cb-cart-page>
  <div class="cb-container">
    <h1 style="margin: 32px 0 24px;">Your cart</h1>

    <div class="cb-cart" id="cb-cart-filled" style="display:none;">
      <div class="cb-cart-list cb-anim-up" id="cb-cart-items">
        <!-- JS renders cart items here -->
      </div>

      <aside class="cb-cart-summary cb-anim-up delay-1" id="cb-cart-summary">
        <h3>Order summary</h3>
        <div class="cb-summary-row">
          <span>Subtotal</span>
          <span id="cb-cart-subtotal">Rs. 0</span>
        </div>
        <div class="cb-summary-row cb-total">
          <span>Total</span>
          <span id="cb-cart-total">Rs. 0</span>
        </div>
        <div id="cb-checkout-error" style="display:none;background:#FEF2F2;color:var(--cb-error,#dc2626);padding:0.625rem 0.875rem;border-radius:8px;font-size:0.8rem;margin-top:12px;"></div>
        <button type="button" class="cb-btn cb-btn-primary cb-btn-block cb-btn-lg" style="margin-top: 18px;" id="cb-checkout-btn">
          Checkout →
        </button>
        {% if ordering.whatsapp_order_enabled %}
          <a href="{{ ordering.whatsapp_order_href }}" target="_blank" rel="noopener" class="cb-btn cb-btn-outline cb-btn-block" style="margin-top: 8px;">
            Order on WhatsApp
          </a>
        {% endif %}
      </aside>
    </div>

    <div id="cb-cart-empty" style="display:none; padding: 80px 24px; text-align: center; background: var(--cb-surface); border-radius: var(--cb-radius); border: 1px solid var(--cb-border);">
      <div style="font-size: 4rem; margin-bottom: 16px;">🛒</div>
      <h2>Your cart is empty</h2>
      <p style="color: var(--cb-text-muted); margin-bottom: 24px;">Add a few cheesy bites to get started.</p>
      <a href="/menu" class="cb-btn cb-btn-primary cb-btn-lg">Browse the menu</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "settings": [],
  "presets": [{ "name": "Cart", "settings": {} }]
}
{% endschema %}
