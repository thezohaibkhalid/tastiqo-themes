{% comment %}
  Hero section with three style variants + editable blocks.
  Blocks: heading, text, buttons — each clickable in the editor.
{% endcomment %}

{%- assign style = section.settings.style | default: 'classic' -%}
{%- assign bg_image = section.settings.background_image -%}

<section class="cb-hero cb-hero--{{ style }}"
  {% if style == 'classic' and bg_image != blank %}
    style="background-image: url('{{ bg_image }}');"
  {% endif %}
>

  {%- if style == 'classic' -%}
    <div class="cb-hero-overlay"></div>
    <div class="cb-hero-inner">
      {% for block in section.blocks %}
        {% if block.type == 'heading' %}
          <div data-block-id="{{ block.id }}" data-block-type="heading">
            {% if block.settings.eyebrow != blank %}
              <span class="cb-hero-eyebrow">{{ block.settings.eyebrow }}</span>
            {% endif %}
            <h1 class="cb-hero-title">{{ block.settings.text | default: 'Hand-stretched, wood-fired, cheese-pulled.' }}</h1>
          </div>
        {% elsif block.type == 'text' %}
          <div data-block-id="{{ block.id }}" data-block-type="text">
            <p class="cb-hero-sub">{{ block.settings.text | default: 'Authentic Italian flavours from our kitchen to your door.' }}</p>
          </div>
        {% elsif block.type == 'buttons' %}
          <div data-block-id="{{ block.id }}" data-block-type="buttons" class="cb-hero-actions" style="{% if style == 'classic' or style == 'minimal' %}justify-content: center;{% endif %}">
            {% if block.settings.button1_text != blank %}
              <a href="{{ block.settings.button1_link | default: '/menu' }}" class="cb-btn cb-btn-primary cb-btn-lg">{{ block.settings.button1_text }}</a>
            {% endif %}
            {% if block.settings.button2_text != blank %}
              <a href="{{ block.settings.button2_link | default: '/about' }}" class="cb-btn cb-btn-outline cb-btn-lg" style="{% if style == 'classic' %}border-color: rgba(255,255,255,0.6); color: #fff;{% endif %}">{{ block.settings.button2_text }}</a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        <h1 class="cb-hero-title">{{ section.settings.title | default: 'Hand-stretched, wood-fired, cheese-pulled.' }}</h1>
        <p class="cb-hero-sub">{{ section.settings.subtitle | default: 'Authentic Italian flavours.' }}</p>
        <div class="cb-hero-actions" style="justify-content: center;">
          <a href="/menu" class="cb-btn cb-btn-primary cb-btn-lg">Order now</a>
        </div>
      {% endif %}
    </div>

  {%- elsif style == 'split' -%}
    <div class="cb-hero-grid">
      <div>
        {% for block in section.blocks %}
          {% if block.type == 'heading' %}
            <div data-block-id="{{ block.id }}" data-block-type="heading">
              {% if block.settings.eyebrow != blank %}
                <span class="cb-hero-eyebrow" style="background: var(--cb-secondary); color: var(--cb-accent);">{{ block.settings.eyebrow }}</span>
              {% endif %}
              <h1 class="cb-hero-title" style="color: var(--cb-accent);">{{ block.settings.text | default: 'Pizza done right.' }}</h1>
            </div>
          {% elsif block.type == 'text' %}
            <div data-block-id="{{ block.id }}" data-block-type="text">
              <p class="cb-hero-sub" style="color: var(--cb-text);">{{ block.settings.text | default: 'San Marzano tomatoes. Buffalo mozzarella.' }}</p>
            </div>
          {% elsif block.type == 'buttons' %}
            <div data-block-id="{{ block.id }}" data-block-type="buttons" class="cb-hero-actions">
              {% if block.settings.button1_text != blank %}
                <a href="{{ block.settings.button1_link | default: '/menu' }}" class="cb-btn cb-btn-primary cb-btn-lg">{{ block.settings.button1_text }}</a>
              {% endif %}
              {% if block.settings.button2_text != blank %}
                <a href="{{ block.settings.button2_link | default: '/about' }}" class="cb-btn cb-btn-outline cb-btn-lg">{{ block.settings.button2_text }}</a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}

        {% if section.blocks.size == 0 %}
          <h1 class="cb-hero-title" style="color: var(--cb-accent);">{{ section.settings.title | default: 'Pizza done right.' }}</h1>
          <p class="cb-hero-sub" style="color: var(--cb-text);">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
      <div class="cb-hero-image">
        {% if bg_image != blank %}
          <img src="{{ bg_image }}" alt="">
        {% else %}
          <div class="cb-skeleton" style="width: 100%; height: 100%;"></div>
        {% endif %}
      </div>
    </div>

  {%- else -%}
    <div class="cb-container" style="text-align: center;">
      {% for block in section.blocks %}
        {% if block.type == 'heading' %}
          <div data-block-id="{{ block.id }}" data-block-type="heading">
            {% if block.settings.eyebrow != blank %}
              <span class="cb-hero-eyebrow" style="background: var(--cb-secondary); color: var(--cb-accent);">{{ block.settings.eyebrow }}</span>
            {% endif %}
            <h1 class="cb-hero-title" style="color: var(--cb-accent);">{{ block.settings.text | default: 'Cheesious Bites' }}</h1>
          </div>
        {% elsif block.type == 'text' %}
          <div data-block-id="{{ block.id }}" data-block-type="text">
            <p class="cb-hero-sub" style="margin-left: auto; margin-right: auto;">{{ block.settings.text | default: 'Wood-fired pizzas, ridiculous cheese pulls.' }}</p>
          </div>
        {% elsif block.type == 'buttons' %}
          <div data-block-id="{{ block.id }}" data-block-type="buttons" class="cb-hero-actions" style="justify-content: center;">
            {% if block.settings.button1_text != blank %}
              <a href="{{ block.settings.button1_link | default: '/menu' }}" class="cb-btn cb-btn-primary cb-btn-lg">{{ block.settings.button1_text }}</a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        <h1 class="cb-hero-title" style="color: var(--cb-accent);">{{ section.settings.title | default: 'Cheesious Bites' }}</h1>
        <p class="cb-hero-sub" style="margin-left: auto; margin-right: auto;">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Hero",
  "max_blocks": 6,
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "Layout style",
      "default": "classic",
      "options": [
        { "value": "classic", "label": "Classic — full-bleed image" },
        { "value": "split",   "label": "Split — text + image card" },
        { "value": "minimal", "label": "Minimal — big type, no image" }
      ]
    },
    { "type": "image_picker", "id": "background_image", "label": "Background / hero image" },
    { "type": "text", "id": "title", "label": "Fallback title (used when no blocks)", "default": "Hand-stretched, wood-fired, cheese-pulled." },
    { "type": "textarea", "id": "subtitle", "label": "Fallback subtitle", "default": "Authentic Italian flavours from our kitchen to your door." }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Wood-fired since 2018" },
        { "type": "text", "id": "text", "label": "Heading text", "default": "Hand-stretched, wood-fired, cheese-pulled." }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Text", "default": "Authentic Italian flavours from our kitchen to your door." }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "settings": [
        { "type": "text", "id": "button1_text", "label": "Button 1 text", "default": "Order now" },
        { "type": "url",  "id": "button1_link", "label": "Button 1 link", "default": "/menu" },
        { "type": "text", "id": "button2_text", "label": "Button 2 text", "default": "Our story" },
        { "type": "url",  "id": "button2_link", "label": "Button 2 link", "default": "/about" }
      ]
    }
  ],
  "presets": [{
    "name": "Hero",
    "blocks": [
      { "type": "heading", "settings": { "eyebrow": "Wood-fired since 2018", "text": "Hand-stretched, wood-fired, cheese-pulled." } },
      { "type": "text", "settings": { "text": "Authentic Italian flavours from our kitchen to your door." } },
      { "type": "buttons", "settings": { "button1_text": "Order now", "button1_link": "/menu", "button2_text": "Our story", "button2_link": "/about" } }
    ]
  }]
}
{% endschema %}
