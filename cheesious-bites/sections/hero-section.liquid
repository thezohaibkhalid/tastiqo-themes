{% comment %}
  Hero section with three style variants:
    • classic — full-bleed background image, gradient overlay, centred text
    • split   — left text / right tilted image card
    • minimal — soft gradient background, big type, no image

  Switch via `style` setting in the editor.
{% endcomment %}

{%- assign style = section.settings.style | default: 'classic' -%}
{%- assign bg_image = section.settings.background_image -%}

<section class="cb-hero cb-hero--{{ style }}"
  {% if style == 'classic' and bg_image != blank %}
    style="background-image: url('{{ bg_image }}');"
  {% endif %}
>

  {%- if style == 'classic' -%}
    <div class="cb-hero-overlay"></div>
    <div class="cb-hero-inner">
      {% if section.settings.eyebrow != blank %}
        <span class="cb-hero-eyebrow cb-anim-up">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h1 class="cb-hero-title cb-anim-up delay-1">{{ section.settings.title | default: 'Hand-stretched, wood-fired, cheese-pulled.' }}</h1>
      <p class="cb-hero-sub cb-anim-up delay-2">{{ section.settings.subtitle | default: 'Authentic Italian flavours from our kitchen to your door.' }}</p>
      <div class="cb-hero-actions cb-anim-up delay-3">
        {% if section.settings.cta1_text != blank %}
          <a href="{{ section.settings.cta1_link | default: '/menu' }}" class="cb-btn cb-btn-primary cb-btn-lg">{{ section.settings.cta1_text }}</a>
        {% endif %}
        {% if section.settings.cta2_text != blank %}
          <a href="{{ section.settings.cta2_link | default: '/about' }}" class="cb-btn cb-btn-outline cb-btn-lg" style="border-color: rgba(255,255,255,0.6); color: #fff;">{{ section.settings.cta2_text }}</a>
        {% endif %}
      </div>
    </div>

  {%- elsif style == 'split' -%}
    <div class="cb-hero-grid">
      <div>
        {% if section.settings.eyebrow != blank %}
          <span class="cb-hero-eyebrow cb-anim-up">{{ section.settings.eyebrow }}</span>
        {% endif %}
        <h1 class="cb-hero-title cb-anim-up delay-1">{{ section.settings.title | default: 'Pizza done right.' }}</h1>
        <p class="cb-hero-sub cb-anim-up delay-2">{{ section.settings.subtitle | default: 'San Marzano tomatoes. Buffalo mozzarella. 90 seconds in the wood oven.' }}</p>
        <div class="cb-hero-actions cb-anim-up delay-3">
          {% if section.settings.cta1_text != blank %}
            <a href="{{ section.settings.cta1_link | default: '/menu' }}" class="cb-btn cb-btn-primary cb-btn-lg">{{ section.settings.cta1_text }}</a>
          {% endif %}
          {% if section.settings.cta2_text != blank %}
            <a href="{{ section.settings.cta2_link | default: '/about' }}" class="cb-btn cb-btn-outline cb-btn-lg">{{ section.settings.cta2_text }}</a>
          {% endif %}
        </div>
      </div>
      <div class="cb-hero-image">
        {% if bg_image != blank %}
          <img src="{{ bg_image }}" alt="">
        {% else %}
          <div class="cb-skeleton" style="width: 100%; height: 100%;"></div>
        {% endif %}
      </div>
    </div>

  {%- else -%}
    <div class="cb-container" style="text-align: center;">
      {% if section.settings.eyebrow != blank %}
        <span class="cb-hero-eyebrow cb-anim-up" style="background: var(--color-secondary); color: var(--color-accent);">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h1 class="cb-hero-title cb-anim-up delay-1">{{ section.settings.title | default: 'Cheesious Bites' }}</h1>
      <p class="cb-hero-sub cb-anim-up delay-2" style="margin-left: auto; margin-right: auto;">{{ section.settings.subtitle | default: 'Wood-fired pizzas, ridiculous cheese pulls.' }}</p>
      <div class="cb-hero-actions cb-anim-up delay-3" style="justify-content: center;">
        {% if section.settings.cta1_text != blank %}
          <a href="{{ section.settings.cta1_link | default: '/menu' }}" class="cb-btn cb-btn-primary cb-btn-lg">{{ section.settings.cta1_text }}</a>
        {% endif %}
      </div>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "Layout style",
      "default": "classic",
      "options": [
        { "value": "classic", "label": "Classic — full-bleed image" },
        { "value": "split",   "label": "Split — text + image card" },
        { "value": "minimal", "label": "Minimal — big type, no image" }
      ]
    },
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow",   "default": "Wood-fired since 2018" },
    { "type": "text",     "id": "title",    "label": "Title",     "default": "Hand-stretched, wood-fired, cheese-pulled." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle",  "default": "Authentic Italian flavours from our kitchen to your door." },
    { "type": "image_picker", "id": "background_image", "label": "Background / hero image" },
    { "type": "text", "id": "cta1_text", "label": "Button 1 text", "default": "Order now" },
    { "type": "url",  "id": "cta1_link", "label": "Button 1 link", "default": "/menu" },
    { "type": "text", "id": "cta2_text", "label": "Button 2 text", "default": "Our story" },
    { "type": "url",  "id": "cta2_link", "label": "Button 2 link", "default": "/about" }
  ],
  "presets": [{ "name": "Hero", "settings": {} }]
}
{% endschema %}
