<!DOCTYPE html>
<html lang="{{ localization.locale | default: 'en' }}" dir="{% if localization.rtl %}rtl{% else %}ltr{% endif %}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ seo.title | default: restaurant.name }}</title>
  <meta name="description" content="{{ seo.description | default: restaurant.tagline }}">
  {% if seo.keywords %}<meta name="keywords" content="{{ seo.keywords }}">{% endif %}
  {% if seo.canonical %}<link rel="canonical" href="{{ seo.canonical }}">{% endif %}

  <!-- Open Graph -->
  <meta property="og:title" content="{{ seo.title | default: restaurant.name }}">
  <meta property="og:description" content="{{ seo.description | default: restaurant.tagline }}">
  <meta property="og:type" content="{{ seo.og_type | default: 'website' }}">
  {% if seo.og_image %}<meta property="og:image" content="{{ seo.og_image }}">{% endif %}
  <meta name="twitter:card" content="{{ seo.twitter_card | default: 'summary_large_image' }}">

  <link rel="icon" href="{{ restaurant.icon }}">

  <!-- Fonts -->
  {%- assign fh_font_heading = theme.font_heading | default: 'Playfair Display' -%}
  {%- assign fh_font_body    = theme.font_body    | default: 'DM Sans' -%}
  {%- assign fh_heading_url  = fh_font_heading | replace: ' ', '+' -%}
  {%- assign fh_body_url     = fh_font_body    | replace: ' ', '+' -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family={{ fh_heading_url }}:wght@400;500;600;700;800&family={{ fh_body_url }}:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <style id="fh-theme-tokens">
    :root {
      /* Typography — editable from admin panel */
      --font-heading: '{{ fh_font_heading }}', Georgia, serif;
      --font-body:    '{{ fh_font_body }}', -apple-system, BlinkMacSystemFont, sans-serif;
      --base-font-size: {{ theme.base_font_size | default: 16 }}px;
      --heading-scale:  {{ theme.heading_scale | default: 100 | divided_by: 100.0 }};

      /* Colors — editable from admin panel */
      {% if theme.color_primary %}--color-primary: {{ theme.color_primary }};{% endif %}
      {% if theme.color_secondary %}--color-secondary: {{ theme.color_secondary }};{% endif %}
      {% if theme.color_background %}--color-background: {{ theme.color_background }};{% endif %}
      {% if theme.color_dark %}--color-dark: {{ theme.color_dark }};{% endif %}

      /* Layout — editable from admin panel */
      {% if theme.max_width %}--max-width: {{ theme.max_width }};{% endif %}
      {% if theme.border_radius %}--radius: {{ theme.border_radius }};{% endif %}
    }
  </style>
</head>
<body class="font-body bg-background text-foreground antialiased">

  {% render 'header',
    restaurant: restaurant,
    navigation: navigation,
    branch: branch,
    branch_selector: branch_selector,
    request: request,
    theme: theme,
    ordering: ordering
  %}

  <main id="main-content">
    {{ content_for_layout }}
  </main>

  {% render 'footer',
    restaurant: restaurant,
    navigation: navigation,
    ordering: ordering,
    payments: payments
  %}

  {% render 'branch-selector',
    branch: branch,
    branch_selector: branch_selector,
    request: request
  %}

  {% render 'mobile-bottom-nav',
    request: request,
    ordering: ordering
  %}

  {% render 'floating-whatsapp',
    ordering: ordering
  %}

  {% render 'customer-auth' %}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
