{% comment %}
  Footer Snippet
  Variables: restaurant, navigation, ordering, payments
{% endcomment %}

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">

      {% comment %} Brand & Contact {% endcomment %}
      <div class="footer-brand">
        <h3>{{ restaurant.name }}</h3>
        <p>{{ restaurant.tagline | default: "" }}</p>

        <div class="footer-contact">
          {% if restaurant.address %}
            <a href="#">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {{ restaurant.address }}
            </a>
          {% endif %}
          {% if restaurant.phone %}
            <a href="{{ restaurant.phone | phone_link }}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {{ restaurant.phone }}
            </a>
          {% endif %}
          {% if restaurant.email %}
            <a href="mailto:{{ restaurant.email }}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              {{ restaurant.email }}
            </a>
          {% endif %}
        </div>

        {% if restaurant.social %}
          <div class="footer-social">
            {% if restaurant.social.instagram %}
              <a href="{{ restaurant.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            {% endif %}
            {% if restaurant.social.facebook %}
              <a href="{{ restaurant.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
            {% endif %}
            {% if restaurant.social.whatsapp %}
              <a href="{{ restaurant.social.whatsapp | whatsapp_link }}" target="_blank" rel="noopener" aria-label="WhatsApp">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      {% comment %} Quick Links {% endcomment %}
      <div class="footer-links">
        <h4>Quick Links</h4>
        <ul>
          {% for link in navigation.footer %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      {% comment %} Hours {% endcomment %}
      <div class="footer-hours">
        <h4>Hours</h4>
        <div class="footer-hours-list">
          {% for hour in restaurant.hours %}
            <div class="footer-hours-row">
              <span>{{ hour.day }}</span>
              <span>{% if hour.closed %}Closed{% else %}{{ hour.open }} – {{ hour.close }}{% endif %}</span>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {{ "now" | date: "%Y" }} {{ restaurant.name }}. All rights reserved.</p>

      {% if payments %}
        <div class="footer-payments">
          {% if payments.cod %}Cash on Delivery{% endif %}
          {% if payments.card %}· Card{% endif %}
          {% if payments.jazzcash %}· JazzCash{% endif %}
          {% if payments.easypaisa %}· Easypaisa{% endif %}
        </div>
      {% endif %}

      {% if navigation.legal.size > 0 %}
        <div style="margin-top:0.5rem;">
          {% for link in navigation.legal %}
            <a href="{{ link.url }}" style="opacity:0.6;font-size:0.75rem;">{{ link.title }}</a>
            {% unless forloop.last %} · {% endunless %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>
