{% comment %}
  Menu Card Snippet
  Variables: item (MenuItemContext), ordering, compact (optional bool)
{% endcomment %}

<div class="menu-card {% if compact %}menu-card-compact{% endif %}">
  <a href="{{ item.url }}" class="menu-card-image">
    {% if item.imageUrl %}
      <img src="{{ item.imageUrl }}" alt="{{ item.name }}" loading="lazy">
    {% else %}
      <div style="width:100%;height:100%;background:var(--color-border);display:flex;align-items:center;justify-content:center;color:var(--color-text-muted);">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
    {% endif %}

    {% if item.hasDiscount %}
      <span class="badge badge-primary menu-card-discount">-{{ item.discountPercent }}%</span>
    {% endif %}

    {% if item.isSoldOut %}
      <div class="menu-card-sold-out">
        <span>Sold Out</span>
      </div>
    {% endif %}
  </a>

  <div class="menu-card-body{% if compact %} card-body-compact{% endif %}">
    <a href="{{ item.url }}">
      <h3 class="menu-card-name">{{ item.name }}</h3>
    </a>

    {% unless compact %}
      {% if item.description %}
        <p class="menu-card-desc">{{ item.description | truncatewords: 15 }}</p>
      {% endif %}
    {% endunless %}

    <div class="menu-card-footer">
      <div>
        <span class="menu-card-price">{{ item.priceMoney }}</span>
        {% if item.hasDiscount and compact != true %}
          <span class="menu-card-compare-price">{{ item.compareAtPriceMoney }}</span>
        {% endif %}
      </div>

      {% unless item.isSoldOut %}
        <button class="menu-card-add" aria-label="Add {{ item.name }} to cart" data-item-id="{{ item.id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
      {% endunless %}
    </div>
  </div>
</div>
