{% comment %}
  Header Snippet
  Variables: restaurant, navigation, branch, branch_selector, request, theme, ordering
{% endcomment %}

<header class="site-header">
  {% comment %} Branch bar {% endcomment %}
  {% if branch_selector.has_multiple %}
  <div class="branch-bar">
    <div class="container" style="display:flex;align-items:center;justify-content:space-between;">
      <button data-open-branch-selector style="display:flex;align-items:center;gap:0.25rem;">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>{{ branch.name }}</span>
        <span style="opacity:0.5;">· Change</span>
      </button>
      <a href="{{ restaurant.phone | phone_link }}" style="display:flex;align-items:center;gap:0.25rem;">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>{{ restaurant.phone }}</span>
      </a>
    </div>
  </div>
  {% endif %}

  {% comment %} Main header {% endcomment %}
  <div class="container">
    <div class="header-main">
      {% comment %} Logo + inline branch dropdown {% endcomment %}
      <div class="header-logo-group">
        <a href="/" class="header-logo">
          {% if restaurant.logo %}
            <img src="{{ restaurant.logo }}" alt="{{ restaurant.name }}" style="height:2rem;">
          {% else %}
            {{ restaurant.name }}
          {% endif %}
        </a>

        {% if branch_selector.has_multiple %}
        <div class="branch-dropdown" id="branch-dropdown" style="display: flex; align-items: center;">
          <button class="branch-dropdown-toggle" data-open-branch-selector aria-haspopup="true" aria-expanded="false" style="cursor: pointer;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="branch-dropdown-name">{{ branch.name }}</span>
            <svg class="branch-dropdown-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </div>
        {% endif %}
      </div>

      <nav class="header-nav">
        {% for link in navigation.primary %}
          <a href="{{ link.url }}" class="{% if link.active %}active{% endif %}">
            {{ link.title }}
          </a>
        {% endfor %}
      </nav>

      <div class="header-actions">
        <button class="header-account-btn" id="header-account-btn" aria-label="Account" data-open-auth>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </button>

        <a href="/cart" class="cart-icon" aria-label="Cart">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          <span class="cart-badge" id="header-cart-count" style="display:none;">0</span>
        </a>

        <button class="menu-toggle" id="mobile-menu-toggle" aria-label="Open menu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>

  {% comment %} Mobile menu {% endcomment %}
  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-header">
      <span class="header-logo">{{ restaurant.name }}</span>
      <button id="mobile-menu-close" aria-label="Close menu" style="color:var(--color-text-light);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <nav class="mobile-menu-nav">
      {% for link in navigation.primary %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>

    {% if branch_selector.has_multiple %}
    <div class="mobile-branch-selector" style="padding: 1.5rem; text-align: center;">
        <button data-open-branch-selector class="btn-primary" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.75rem; border-radius: 0.375rem; background: var(--color-primary); color: #fff; font-weight: 600; cursor: pointer; border: none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Change Branch ({{ branch.name }})
        </button>
    </div>
    {% endif %}
  </div>
</header>
