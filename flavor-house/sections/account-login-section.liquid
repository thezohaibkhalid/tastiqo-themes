{% comment %}
  Account Login Section — Shown at /account/login
  Auto-opens the auth modal. Redirects to /account on success.
{% endcomment %}

<section class="account-login-section section-padding">
  <div class="container" style="max-width:28rem;margin:0 auto;text-align:center;padding:4rem 1rem;">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" style="margin:0 auto 1rem;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    <h1 style="margin-bottom:0.5rem;">Sign In</h1>
    <p class="text-muted" style="margin-bottom:2rem;">Enter your email to sign in or create an account.</p>
    <button class="btn btn-primary btn-full" data-open-auth id="login-page-cta">Sign In with Email</button>
    <p class="text-muted" style="margin-top:1.5rem;font-size:0.8rem;">We'll send you a verification code. No password needed.</p>
  </div>
</section>

<script>
  // Auto-open auth modal when visiting /account/login
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof window.openAuthModal === 'function') {
      window.openAuthModal();
    }
  });
</script>
