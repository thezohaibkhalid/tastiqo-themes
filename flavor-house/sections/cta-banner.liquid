{% comment %} CTA Banner — Call to action with dark background {% endcomment %}

{% if section.settings.visible != false %}
<section class="cta-banner">
  <div class="container">
    <h2>{{ section.settings.title | default: "Hungry? Let's Fix That." }}</h2>
    <p>{{ section.settings.subtitle | default: "Order now and get freshly prepared meals delivered to your door." }}</p>

    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      {% if section.settings.cta_text %}
        <a href="{{ section.settings.cta_link | default: '/menu' }}" class="btn btn-{{ section.settings.cta_style | default: 'primary' }} btn-lg">
          {{ section.settings.cta_text }}
        </a>
      {% endif %}

      {% if section.settings.show_whatsapp and ordering.whatsappOrderEnabled %}
        <a href="{{ ordering.whatsappOrderHref }}" target="_blank" rel="noopener" class="btn btn-lg" style="background:#25D366;color:#fff;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.61.609l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.387 0-4.592-.838-6.313-2.236l-.44-.368-3.265 1.094 1.094-3.265-.368-.44A9.956 9.956 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
          WhatsApp Order
        </a>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "checkbox",
      "id": "visible",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Hungry? Let's Fix That."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Order now and get freshly prepared meals delivered to your door."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Order Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link",
      "default": "/menu"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "Button Style",
      "default": "primary",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_whatsapp",
      "label": "Show WhatsApp Button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "CTA Banner",
      "settings": {}
    }
  ]
}
{% endschema %}
