{% comment %} Announcement Bar — Top banner with promo message {% endcomment %}

{% if section.settings.enabled %}
<div class="announcement-bar" {% if section.settings.bg_color %}style="background-color: {{ section.settings.bg_color }};"{% endif %}>
  <div class="container">
    {{ section.settings.text }}
    {% if section.settings.link_text and section.settings.link %}
      <a href="{{ section.settings.link }}">{{ section.settings.link_text }} →</a>
    {% endif %}
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable Announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "🔥 Free delivery on orders above Rs.1,500!"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link URL",
      "default": "/menu"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "Order Now"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#E11D48"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "settings": { "enabled": true, "text": "Free delivery on orders above Rs.1,500!" }
    }
  ]
}
{% endschema %}
