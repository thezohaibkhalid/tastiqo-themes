{% comment %} Collection page — shows a single category with all its items (Chunk N Cheese). {% endcomment %}

{%- assign style = section.settings.card_style | default: 'elevated' -%}
{%- assign cols = section.settings.columns | default: 3 -%}

<section class="cnc-section">
  <div class="cnc-container">
    {% if collection %}
      <div class="cnc-section-head cnc-anim-up" style="margin-bottom:40px;">
        <h1 style="font-size: clamp(2rem, 4vw, 3rem);">{{ collection.title }}</h1>
        {% if collection.description != blank %}
          <p style="color:var(--cnc-text-muted);max-width:600px;">{{ collection.description }}</p>
        {% endif %}
        <span style="color:var(--cnc-text-muted);font-size:0.9rem;">{{ collection.items.size }} items</span>
      </div>

      {% if collection.image != blank %}
        <div style="border-radius:16px;overflow:hidden;margin-bottom:40px;max-height:300px;">
          <img src="{{ collection.image }}" alt="{{ collection.title }}" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
        </div>
      {% endif %}

      <div class="cnc-grid" style="--cnc-cols: {{ cols }};">
        {% for item in collection.items %}

          {%- if style == 'minimal' -%}
            <a href="{{ item.url }}" class="cnc-card--minimal cnc-anim-up">
              <div class="cnc-card-img">
                {% if item.imageUrl != blank %}<img src="{{ item.imageUrl }}" alt="{{ item.name }}" loading="lazy">{% else %}<div class="cnc-skeleton" style="width:100%;height:100%;"></div>{% endif %}
              </div>
              <div class="cnc-card-title">{{ item.name }}</div>
              <div class="cnc-card-price">{{ item.price | money }}</div>
            </a>

          {%- elsif style == 'slide-cart' -%}
            <a href="{{ item.url }}" class="cnc-card--slide-cart cnc-anim-up">
              <div class="cnc-card-img">
                {% if item.imageUrl != blank %}<img src="{{ item.imageUrl }}" alt="{{ item.name }}" loading="lazy">{% else %}<div class="cnc-skeleton" style="width:100%;height:100%;"></div>{% endif %}
                <div class="cnc-card-tags">
                  {% if item.featured %}<span class="cnc-pill cnc-pill-hot">🔥</span>{% endif %}
                  {% if item.tags contains 'new' %}<span class="cnc-pill cnc-pill-new">New</span>{% endif %}
                </div>
              </div>
              <div class="cnc-card-body">
                <div class="cnc-card-title">{{ item.name }}</div>
                {% if item.description != blank %}<p class="cnc-card-desc">{{ item.description | truncate: 80 }}</p>{% endif %}
                <div class="cnc-card-price">{{ item.price | money }}</div>
              </div>
              <div class="cnc-card-cart-btn">+ Add to Cart</div>
            </a>

          {%- elsif style == 'compact' -%}
            <a href="{{ item.url }}" class="cnc-card--compact cnc-anim-up">
              <div class="cnc-card-img">
                {% if item.imageUrl != blank %}<img src="{{ item.imageUrl }}" alt="{{ item.name }}" loading="lazy">{% else %}<div class="cnc-skeleton" style="width:100%;height:100%;"></div>{% endif %}
              </div>
              <div class="cnc-card-body">
                <div class="cnc-card-title">{{ item.name }}</div>
                {% if item.description != blank %}<p class="cnc-card-desc">{{ item.description | truncate: 70 }}</p>{% endif %}
                <div class="cnc-card-foot">
                  <span class="cnc-card-price">{{ item.price | money }}</span>
                  <span class="cnc-btn cnc-btn-primary cnc-btn-sm">Add</span>
                </div>
              </div>
            </a>

          {%- else -%}
            <a href="{{ item.url }}" class="cnc-card--elevated cnc-anim-up">
              <div class="cnc-card-img">
                {% if item.imageUrl != blank %}<img src="{{ item.imageUrl }}" alt="{{ item.name }}" loading="lazy">{% else %}<div class="cnc-skeleton" style="width:100%;height:100%;"></div>{% endif %}
                <div class="cnc-card-tags">
                  {% if item.featured %}<span class="cnc-pill cnc-pill-hot">🔥</span>{% endif %}
                  {% if item.tags contains 'new' %}<span class="cnc-pill cnc-pill-new">New</span>{% endif %}
                </div>
              </div>
              <div class="cnc-card-body">
                <div class="cnc-card-title">{{ item.name }}</div>
                {% if item.description != blank %}<p class="cnc-card-desc">{{ item.description | truncate: 100 }}</p>{% endif %}
                <div class="cnc-card-foot">
                  <span class="cnc-card-price">{{ item.price | money }}</span>
                  <span class="cnc-btn cnc-btn-primary cnc-btn-sm">Add</span>
                </div>
              </div>
            </a>
          {%- endif -%}

        {% endfor %}
      </div>

    {% else %}
      <div style="text-align:center;padding:4rem 0;">
        <h2 class="cnc-heading-lg">Category not found</h2>
        <p style="color:var(--cnc-text-muted);margin-bottom:1.5rem;">The category you're looking for doesn't exist.</p>
        <a href="/menu" class="cnc-btn cnc-btn-primary">Browse Full Menu</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "select",
      "id": "card_style",
      "label": "Card design",
      "default": "elevated",
      "options": [
        { "value": "minimal",    "label": "Minimal" },
        { "value": "elevated",   "label": "Elevated card" },
        { "value": "slide-cart", "label": "Slide-in Add to Cart" },
        { "value": "compact",   "label": "Compact (horizontal)" }
      ]
    },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 4, "step": 1, "default": 3 }
  ],
  "presets": [{ "name": "Collection", "settings": {} }]
}
{% endschema %}
