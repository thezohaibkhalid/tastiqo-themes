{% comment %}
  Header section — editable in the theme editor.
  Renders the sticky top bar with logo, nav, branch picker, and cart.
  Settings allow toggling search/cart icons and choosing mobile menu style.
{% endcomment %}

<header class="cnc-header" data-cnc-header>
  <div class="cnc-header-inner">

    <a href="/" class="cnc-logo" aria-label="{{ restaurant.name }}">
      {% if theme.logo_image != blank %}
        <img src="{{ theme.logo_image }}" alt="{{ restaurant.name }}" class="cnc-logo-img">
      {% elsif restaurant.logo %}
        <img src="{{ restaurant.logo }}" alt="{{ restaurant.name }}" class="cnc-logo-img">
      {% else %}
        <span class="cnc-logo-mark">🍔</span>
        <span class="cnc-logo-text">{{ restaurant.name | default: "Chunk N Cheese" }}</span>
      {% endif %}
    </a>

    <nav class="cnc-nav" aria-label="Primary">
      {% for item in navigation.primary %}
        <a href="{{ item.url }}" class="cnc-nav-link {% if item.active %}is-active{% endif %}">{{ item.title }}</a>
      {% endfor %}
    </nav>

    <div class="cnc-header-right">

      {% if branch_selector and branch_selector.branches and branch_selector.branches.size > 1 %}
        <button type="button" class="cnc-branch-trigger" data-cnc-branch-trigger aria-label="Choose branch" aria-expanded="false">
          <span class="cnc-branch-icon">📍</span>
          <span class="cnc-branch-name">{{ branch.name | default: "Pick branch" }}</span>
          <span class="cnc-branch-caret">▾</span>
        </button>
        <div class="cnc-branch-menu" data-cnc-branch-menu hidden>
          <div class="cnc-branch-menu-head">Choose your branch</div>
          {% for b in branch_selector.branches %}
            <form method="post" action="/api/storefront/set-branch" class="cnc-branch-row {% if branch.id == b.id %}is-selected{% endif %}">
              <input type="hidden" name="branch_id" value="{{ b.id }}">
              <button type="submit">
                <div class="cnc-branch-row-name">{{ b.name }}</div>
                {% if b.address %}<div class="cnc-branch-row-addr">{{ b.address }}</div>{% endif %}
                {% if b.is_open %}<span class="cnc-pill cnc-pill-open">Open now</span>{% else %}<span class="cnc-pill cnc-pill-closed">Closed</span>{% endif %}
              </button>
            </form>
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.show_search %}
        <a href="/search" class="cnc-icon-btn" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </a>
      {% endif %}

      <button type="button" class="cnc-icon-btn" data-open-auth aria-label="Account">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </button>

      {% if section.settings.show_cart %}
        <a href="/cart" class="cnc-cart-link" aria-label="Cart">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
          <span class="cnc-cart-badge" data-cnc-cart-count style="display:none"></span>
        </a>
      {% endif %}

      <button type="button" class="cnc-mobile-toggle" data-cnc-mobile-toggle aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="cnc-mobile-drawer" data-cnc-mobile-drawer hidden>
    <nav class="cnc-mobile-nav" aria-label="Mobile">
      {% for item in navigation.primary %}
        <a href="{{ item.url }}" class="cnc-mobile-link {% if item.active %}is-active{% endif %}">{{ item.title }}</a>
      {% endfor %}
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "checkbox", "id": "show_search", "label": "Show search icon", "default": false },
    { "type": "checkbox", "id": "show_cart", "label": "Show cart icon", "default": true },
    {
      "type": "select",
      "id": "mobile_style",
      "label": "Mobile menu style",
      "default": "drawer",
      "options": [
        { "value": "drawer", "label": "Slide-down drawer" },
        { "value": "fullscreen", "label": "Fullscreen overlay" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Nav Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Link" },
        { "type": "url", "id": "url", "label": "URL", "default": "/" }
      ]
    }
  ],
  "presets": [{ "name": "Header", "settings": {} }]
}
{% endschema %}
