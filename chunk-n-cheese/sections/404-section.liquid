{% comment %} 404 page section (Chunk N Cheese). {% endcomment %}

<section class="cnc-section" style="text-align: center;">
  <div class="cnc-container" style="max-width: 560px;">
    <div style="font-size: 6rem; line-height: 1; margin-bottom: 12px;" class="cnc-anim-up">🧀</div>
    <h1 class="cnc-anim-up delay-1" style="margin-bottom: 12px;">{{ section.settings.title | default: 'Page not found' }}</h1>
    <p class="cnc-anim-up delay-2" style="color: var(--cnc-text-muted); margin-bottom: 32px;">
      {{ section.settings.body | default: "Looks like this chunk of cheese rolled off the board. Let's get you back to the menu." }}
    </p>
    <div class="cnc-anim-up delay-3" style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
      <a href="/" class="cnc-btn cnc-btn-primary cnc-btn-lg">Back home</a>
      <a href="/menu" class="cnc-btn cnc-btn-outline cnc-btn-lg">Browse menu</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Page not found" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Looks like this chunk of cheese rolled off the board. Let's get you back to the menu." }
  ],
  "presets": [{ "name": "404", "settings": {} }]
}
{% endschema %}
